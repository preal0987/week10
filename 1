clear; clc;
t = 0:0.01:30;
f = exp(-0.12*t).*sin(5*t) + 0.3*cos(2*t);
plot(t, f)
title('f(t)')
xlabel('t')
ylabel('f(t)')
grid on
hold on
u = exp(-0.12*t) + 0.3;
l = -exp(-0.12*t) - 0.3;
plot(t, u)
plot(t, l)
idx = find(f(2:end-1) > f(1:end-2) & f(2:end-1) > f(3:end)) + 1;
plot(t(idx), f(idx), 'o')
hold off
result = [t(idx)' f(idx)'];
disp('국소 최대값 (t, f(t)) =')
disp(result)
